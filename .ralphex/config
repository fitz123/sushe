# Ralphex config for sushe bot
max_iterations = 10
branch_prefix = ralphex/

# Claude Code args
claude_args = --dangerously-skip-permissions --output-format stream-json --verbose --model opus

# Codex review
codex_enabled = true
codex_model = gpt-5.3-codex
codex_reasoning_effort = xhigh

# Notifications
notify_channels = custom
notify_custom_script = ~/.minime/workspace/.ralphex/scripts/notify-minime.sh
