# Ralphex config for sushe bot
max_iterations = 5
branch_prefix = ralphex/

# Claude Code args
claude_args = --dangerously-skip-permissions --output-format stream-json --verbose --model sonnet

# Codex review
codex_enabled = true
codex_model = gpt-5.3-codex
codex_reasoning_effort = high

# Notifications
notify_channels = custom
notify_custom_script = .ralphex/scripts/notify-openclaw.sh
