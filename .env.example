# Server connection (must match an entry in ~/.ssh/config with HostName, User, IdentityFile)
SSH_HOST="your-ssh-host"

# SSH public key for remote user (from ~/.ssh/id_ed25519.pub or similar)
SSH_PUBLIC_KEY=""

# Application
TELEGRAM_BOT_TOKEN=""

# Telegram API credentials (from https://my.telegram.org)
# Required for local Bot API server (enables 2GB uploads)
TELEGRAM_API_ID=""
TELEGRAM_API_HASH=""
